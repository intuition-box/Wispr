        "firecrawl-mcp",
        "embeddings-matching-skill",
        "mcp-gmail",
        "claude-haiku-4-5"
      ],
      "infrastructure": [
        "Daily cron job at 08:00 (Vercel Cron, GitHub Actions, etc.)"
      ],
      "flow": "Cron 08:00 → Firecrawl MCP scrapes job boards → Embeddings Matching Skill scores vs profile → threshold filter → MCP Gmail sends matches"
    }
