      "components": [
        "mcp-github",
        "code-review-skill",
        "claude-sonnet-4-5"
      ],
      "infrastructure": [
        "GitHub webhook trigger (fires on PR opened event)"
      ],
      "flow": "PR opened → webhook → MCP GitHub reads diff → Claude Sonnet + Code Review Skill → comment posted on PR"
    },
    "w3-job-scraper": {
